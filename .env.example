# ==========================================================
# AuraAI Creator OS - Example Environment Configuration
# ==========================================================
#
# Copy this file as ".env" and add your private values there.
# Never upload or commit the real .env file.
#

# ----------------------------------------------------------
# Application
# ----------------------------------------------------------

AURAAI_APP_NAME=AuraAI Creator OS
AURAAI_APP_VERSION=2.0.0-dev
AURAAI_ENV=development
AURAAI_DEBUG=true


# ----------------------------------------------------------
# AI provider
# ----------------------------------------------------------

AURAAI_DEFAULT_AI_PROVIDER=gemini

# Add the real key only inside your private .env file.
GEMINI_API_KEY=your_gemini_api_key_here

AURAAI_GEMINI_MODEL=gemini-flash-latest
AURAAI_AI_TEMPERATURE=0.2
AURAAI_AI_MAX_OUTPUT_TOKENS=4096


# ----------------------------------------------------------
# Whisper transcription
# ----------------------------------------------------------

AURAAI_WHISPER_MODEL=tiny

# Leave empty to let Whisper detect the language automatically.
AURAAI_WHISPER_LANGUAGE=

# Use false for CPU-based transcription.
AURAAI_WHISPER_USE_FP16=false


# ----------------------------------------------------------
# Video downloading
# ----------------------------------------------------------

AURAAI_VIDEO_DOWNLOAD_FORMAT=bestvideo[ext=mp4]+bestaudio[ext=m4a]/bestvideo+bestaudio/best
AURAAI_VIDEO_DOWNLOAD_TIMEOUT_SECONDS=60
AURAAI_VIDEO_DOWNLOAD_RETRIES=5

# Maximum accepted source-video duration.
# 7200 seconds equals 2 hours.
AURAAI_MAX_VIDEO_DURATION_SECONDS=7200


# ----------------------------------------------------------
# Logging
# ----------------------------------------------------------

AURAAI_LOG_LEVEL=INFO
AURAAI_LOG_TO_CONSOLE=true
AURAAI_LOG_TO_FILE=true


# ----------------------------------------------------------
# Database
# ----------------------------------------------------------

# Leave this unset initially to use:
# data/database/auraai.db
#
# AURAAI_DATABASE_URL=